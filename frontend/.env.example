# Google OAuth — create credentials at https://console.cloud.google.com
# Application type: Web application
# Authorised JavaScript origins: http://localhost:5173 (dev) + your prod domain
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# API base URL (leave blank to use default: localhost:3001 in dev, /api in prod)
# VITE_API_URL=https://your-backend.example.com/api
