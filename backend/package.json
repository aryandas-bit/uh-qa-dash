{
  "name": "qa-dashboard-backend",
  "version": "1.0.0",
  "description": "QA Dashboard API server",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx/esm src/app.ts",
    "build": "tsc && cp -r src/data dist/",
    "start": "node dist/app.js",
    "sync": "node --import tsx/esm src/scripts/sync-metabase.ts",
    "import-csv": "node --import tsx/esm src/scripts/import-csv.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@libsql/client": "^0.14.0",
    "@types/multer": "^2.1.0",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.2.1",
    "dotenv": "^16.4.5",
    "esbuild": "^0.27.3",
    "express": "^4.21.0",
    "googleapis": "^171.4.0",
    "multer": "^2.1.1",
    "node-cache": "^5.1.2",
    "openai": "^4.60.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
