# QA Dashboard Backend — Environment Variables

# Server
PORT=3001

# Auth — REQUIRED. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-use-a-long-random-secret-min-48-chars

# Turso Cloud DB
TURSO_DB_URL=libsql://your-db.turso.io
TURSO_DB_TOKEN=your-turso-token
TURSO_REVIEWS_URL=libsql://your-reviews-db.turso.io
TURSO_REVIEWS_TOKEN=your-reviews-token

# AI providers
GEMINI_API_KEY=your-gemini-key
GROQ_API_KEY=your-groq-key

# Google Sheets
GOOGLE_SHEET_ID=your-sheet-id
GOOGLE_CREDENTIALS_PATH=/path/to/service-account.json
